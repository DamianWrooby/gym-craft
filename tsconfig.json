{
    "extends": "./.svelte-kit/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "baseUrl": ".",
        "types": ["@testing-library/jest-dom"],
        "paths": {
            "$lib": ["./src/lib"],
            "$lib/*": ["./src/lib/*"],
            "@/*": ["src/*"],
            "@components/*": ["src/lib/components/*"],
            "@models/*": ["src/models/*"],
            "@assets/*": ["src/assets/*"]
        }
    }
}
